<PropertyValue Property="Value" Path="joinDate"/>
</Record>
<Record Type="UI.DataField">
<PropertyValue Property="Value" Path="jobId"/>
</Record>
<Record Type="UI.DataField">
<PropertyValue Property="Value" Path="salary"/>
</Record>
<Record Type="UI.DataField">
<PropertyValue Property="Value" Path="managerId"/>
</Record>
<Record Type="UI.DataField">
<PropertyValue Property="Value" Path="departmentId"/>
</Record>
<Record Type="UI.DataField">
<PropertyValue Property="Value" Path="maritalStatus"/>
</Record>
</Collection>
</Annotation>
</Annotations>
